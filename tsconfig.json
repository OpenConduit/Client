{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": {
      "@openconduit/core": ["packages/core/src/index.ts"],
      "@openconduit/core/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages/**/*"]
}
